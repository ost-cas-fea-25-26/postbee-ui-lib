{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "types": ["react", "react-dom"],
    "outDir": "./lib/cjs",
    "declaration": true,
    "declarationDir": "./lib/types",
    "noEmit": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": ["src/components/**/*"]
}
